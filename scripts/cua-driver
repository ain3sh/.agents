#!/usr/bin/env bash
set -euo pipefail

REAL_CUA_DRIVER="${CUA_DRIVER_REAL:-/home/ain3sh/.local/bin/cua-driver}"
if [[ ! -x "$REAL_CUA_DRIVER" ]]; then
  cleaned_path="$(printf '%s' "$PATH" | tr ':' '\n' | grep -vx "$HOME/.agents/scripts" | paste -sd: -)"
  REAL_CUA_DRIVER="$(PATH="$cleaned_path" command -v cua-driver || true)"
fi

if [[ -z "${REAL_CUA_DRIVER:-}" || ! -x "$REAL_CUA_DRIVER" ]]; then
  echo "cua-driver wrapper: real cua-driver not found" >&2
  exit 127
fi

export CUA_DRIVER_RS_ENABLE_WAYLAND="${CUA_DRIVER_RS_ENABLE_WAYLAND:-1}"
export CUA_DRIVER_CDP_PORT="${CUA_DRIVER_CDP_PORT:-9222}"

if [[ -z "${CUA_WAYLAND_NEST+x}" && "${XDG_SESSION_TYPE:-}" == "wayland" ]]; then
  case "${XDG_CURRENT_DESKTOP:-}" in
    *KDE*|*GNOME*) export CUA_WAYLAND_NEST=1 ;;
  esac
fi

if [[ "${CUA_WAYLAND_NEST:-}" == "1" && -z "${CUA_WAYLAND_NEST_COMPOSITOR:-}" ]]; then
  if command -v labwc >/dev/null 2>&1; then
    export CUA_WAYLAND_NEST_COMPOSITOR=labwc
  elif command -v sway >/dev/null 2>&1; then
    export CUA_WAYLAND_NEST_COMPOSITOR=sway
  else
    unset CUA_WAYLAND_NEST
    if [[ "${CUA_DRIVER_WRAPPER_WARN:-}" == "1" ]]; then
      echo "cua-driver wrapper: labwc/sway missing; using XWayland fallback instead of nested Wayland" >&2
    fi
  fi
fi

if [[ "${1:-}" == "call" && "${2:-}" == "launch_app" && $# -ge 3 ]] && command -v jq >/dev/null 2>&1; then
  rewritten_json="$(
    jq -cer '
      def with_flag($flag):
        if contains($flag) then . else . + " " + $flag end;

      if ((.launch_path // .name // "") | test("helium"; "i")) then
        .launch_path = (
          (.launch_path // "helium-browser")
          | with_flag("--ozone-platform=x11")
          | with_flag("--remote-debugging-port=" + (env.CUA_DRIVER_CDP_PORT // "9222"))
          | with_flag("--no-first-run")
        )
        | del(.name)
      else
        .
      end
    ' <<< "$3" 2>/dev/null || true
  )"

  if [[ -n "$rewritten_json" ]]; then
    args=("$@")
    args[2]="$rewritten_json"
    exec "$REAL_CUA_DRIVER" "${args[@]}"
  fi
fi

exec "$REAL_CUA_DRIVER" "$@"
